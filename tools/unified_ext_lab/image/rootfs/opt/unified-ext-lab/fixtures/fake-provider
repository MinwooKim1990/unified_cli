#!/usr/bin/python3
"""Deterministic synthetic protocol fixture; never contacts a service."""

from __future__ import annotations

import json
import os
import sys


def main() -> int:
    if sys.argv != [sys.argv[0], "protocol-check"]:
        return 2
    marker = "/workspace/project.marker"
    payload = {
        "artifact": "synthetic-cli-fixture",
        "marker": os.path.isfile(marker),
        "protocol": 1,
        "status": "ok",
        "version": "1.0.0",
    }
    print(json.dumps(payload, separators=(",", ":"), sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
