# Documentation and metadata to ship in the sdist
include LICENSE
include README.md
include README.ko.md
include USAGE.md
include USAGE.ko.md
include CHANGELOG.md

# Typed marker
include src/unified_cli/py.typed

# Keep the test suite in the sdist
recursive-include tests *.py
# Repository-release tests depend on source-only scripts, workflows, or release
# docs and are not part of the installable Core sdist test contract.
exclude tests/test_distribution_pair.py
exclude tests/test_performance_contract.py
exclude tests/test_release_artifacts.py
exclude tests/test_release_contract.py

# Exclude internal development docs
exclude FIX_PLAN.md
exclude PHASE0_VERIFICATION.md
exclude UX_TEST_REPORT.md
exclude simulation.md

# The extension labs are source-checkout development harnesses, not Core
# package content. Keep every lab module and launcher out of the Core archive.
prune tools
exclude scripts/unified-ext-lab*

# Prune build/dev/cache noise
prune .venv
prune .codegraph
prune .pytest_cache
prune workflows

# Drop bytecode and OS cruft everywhere
global-exclude __pycache__ *.py[cod] .DS_Store
